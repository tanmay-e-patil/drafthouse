# === Dokploy Host-Level Vars ===

# Required (no defaults - set these on your Dokploy host / Infisical)
APP_ORIGIN=https://your-domain.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional
APP_PORT=8080
POSTGRES_USER=drafthouse
POSTGRES_PASSWORD=drafthouse
POSTGRES_DB=drafthouse

# === App-Level Vars (all optional, have defaults) ===

BIND_ADDR=0.0.0.0:8080
RUST_LOG=ERROR
DATABASE_URL=postgres://drafthouse:drafthouse@localhost:5432/drafthouse
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRY_SECS=900
REFRESH_TOKEN_EXPIRY_DAYS=30
EMAIL_FROM=Drafthouse <onboarding@tanmayep.dev>
RESEND_API_BASE_URL=https://api.resend.com
SCYLLA_NODES=127.0.0.1:9042
SCYLLA_KEYSPACE=drafthouse
SCYLLA_REPLICATION_FACTOR=1
MIGRATIONS_DIR=migrations/postgres
SCYLLA_MIGRATIONS_DIR=migrations/scylla
